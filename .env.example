# ─── Cloudinary media delivery (Tier-2, optional) ───────────────────────────
# Set either var to enable Cloudinary URL rewriting via src/lib/cloudinary.ts.
# Without this the site works normally; all <img src={cld(...)}> calls fall back
# to the original local/static path.
#
# Find your cloud name at: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API credentials (needed only for server-side upload/management API,
# NOT required for client-side delivery URL generation).
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Gemini / AI agents ──────────────────────────────────────────────────────
# Used by src/lib/gemini.ts for FrequencyFinder, TrackBriefGenerator,
# DataDragonsDiagnostic interactive tools.
GEMINI_API_KEY=
OPENROUTER_API_KEY=
